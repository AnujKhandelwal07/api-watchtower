generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Provider {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  baseUrl       String?
  specUrl       String?
  authType      String
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  snapshots     Snapshot[]
  snapshotDiffs SnapshotDiff[]
  alerts        Alert[]
}

model Snapshot {
  id           String         @id @default(cuid())
  providerId   String
  provider     Provider       @relation(fields: [providerId], references: [id], onDelete: Cascade)
  sourceUrl    String
  status       String
  httpStatus   Int?
  contentType  String?
  rawPayload   Json?
  errorMessage String?
  createdAt    DateTime       @default(now())
  diffsFrom    SnapshotDiff[] @relation("PreviousSnapshot")
  diffsTo      SnapshotDiff[] @relation("CurrentSnapshot")

  @@index([providerId, createdAt])
}

model SnapshotDiff {
  id                 String   @id @default(cuid())
  providerId         String
  provider           Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  previousSnapshotId String
  currentSnapshotId  String
  previousSnapshot   Snapshot @relation("PreviousSnapshot", fields: [previousSnapshotId], references: [id], onDelete: Cascade)
  currentSnapshot    Snapshot @relation("CurrentSnapshot", fields: [currentSnapshotId], references: [id], onDelete: Cascade)
  hasChanges         Boolean
  summary            Json?
  createdAt          DateTime @default(now())
  alerts        Alert[]

  @@unique([previousSnapshotId, currentSnapshotId])
  @@index([providerId, createdAt])
}

model Alert {
  id           String    @id @default(cuid())
  providerId   String
  diffId       String
  provider     Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  diff         SnapshotDiff @relation(fields: [diffId], references: [id], onDelete: Cascade)
  type         String    @default("CHANGE_DETECTED")
  message      String
  isRead       Boolean   @default(false)
  acknowledgedAt DateTime?
  snsMessageId   String?
  createdAt    DateTime  @default(now())

  @@index([providerId, createdAt])
  @@index([isRead])
}
